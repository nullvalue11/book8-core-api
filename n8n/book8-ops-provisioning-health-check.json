      "name": "Switch on Mode",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [320, 110]
    },
    {
      "parameters": {
        "url": "=https://book8-core-api.onrender.com/api/health/business/{{ $json.businessId }}",
        "sendHeaders": true,
        "headerParameters": {
