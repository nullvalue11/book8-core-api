      "id": "a1b2c3d4-iff-0018",
      "name": "Still Failing",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [2700, 280]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.resend.com/emails",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.RESEND_API_KEY }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: 'alerts@book8.io', to: ['YOUR_ALERT_EMAIL@example.com'], subject: 'Book8 AI — Provisioning failed: ' + ($('Enrich After Recheck').item.json.businessId || 'unknown'), html: '<h2>Provisioning health check failed</h2><p><strong>Business:</strong> ' + ($('Enrich After Recheck').item.json.businessId || '') + '</p><p><strong>Status:</strong> ' + ($('Enrich After Recheck').item.json.status || '') + '</p><pre>' + JSON.stringify($('Enrich After Recheck').item.json.checks || {}, null, 2) + '</pre><p>tenant.ensure was retried; critical checks still failing. Manual follow-up required.</p>' }) }}",
        "options": {}
      },
      "id": "a1b2c3d4-rsd-0019",
      "name": "Send Alert Resend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2960, 180],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const h = $('Enrich After Recheck').item.json;\nreturn [{\n  json: {\n    ok: h.ok,\n    businessId: h.businessId,\n    status: h.status,\n    checks: h.checks,\n    message: h.ok ? 'Recheck passed after retry' : 'Still failing after retry',\n    respond: h._flowRespond\n  }\n}];"
      },
