              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "x-ops-secret",
              "value": "={{ $env.N8N_OPS_SECRET }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ tool: 'tenant.ensure', input: { businessId: $json.businessId }, dryRun: false }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "a1b2c3d4-rty-0013",
      "name": "Retry Execute Tool",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1600, 280],
      "continueOnFail": true
