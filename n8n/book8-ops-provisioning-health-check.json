      },
      "id": "a1b2c3d4-h1s-0005",
      "name": "Health Check Single",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [580, 0]
    },
    {
      "parameters": {
        "url": "https://book8-core-api.onrender.com/api/health/all",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-internal-secret",
              "value": "={{ $env.CORE_API_INTERNAL_SECRET }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "a1b2c3d4-hall-0006",
      "name": "Health Check All",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [580, 220]
    },
    {
      "parameters": {
        "jsCode": "const dm = $('Determine Mode').first().json;\nconst respond = !!dm.respond;\nconst mode = dm.mode;\nconst input = $json;\n\nif (input.businesses) {\n  const incomplete = input.businesses.filter((b) => b.status === 'INCOMPLETE');\n  if (incomplete.length === 0) {\n    return [{\n      json: {\n        allHealthy: true,\n        total: input.total,\n        ready: input.ready,\n        incomplete: 0,\n        businessesToRetry: [],\n        respond,\n        mode\n      }\n    }];\n  }\n  return [{\n    json: {\n      allHealthy: false,\n      total: input.total,\n      ready: input.ready,\n      incomplete: incomplete.length,\n      businessesToRetry: incomplete.map((b) => ({\n        businessId: b.businessId,\n        name: b.name,\n        hasServices: b.hasServices,\n        hasSchedule: b.hasSchedule,\n        hasPhone: b.hasPhone,\n        hasCalendar: b.hasCalendar,\n        hasElevenLabs: b.hasElevenLabs\n      })),\n      respond,\n      mode\n    }\n  }];\n}\n\nif (input.status === 'FULLY_PROVISIONED' || input.status === 'PARTIALLY_PROVISIONED') {\n  return [{\n    json: {\n      allHealthy: true,\n      total: 1,\n      ready: 1,\n      incomplete: 0,\n      businessesToRetry: [],\n      respond,\n      mode\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    allHealthy: false,\n    total: 1,\n    ready: 0,\n    incomplete: 1,\n    businessesToRetry: [{\n      businessId: input.businessId,\n      name: input.raw?.name || 'unknown',\n      hasServices: input.checks?.services?.ok || false,\n      hasSchedule: input.checks?.schedule?.ok || false,\n      hasPhone: input.checks?.phone_number?.ok || false,\n      hasCalendar: input.checks?.calendar?.ok || false,\n      hasElevenLabs: input.checks?.elevenlabs?.ok || false\n    }],\n    respond,\n    mode\n  }\n}];"
      },
      "id": "a1b2c3d4-norm-0007",
      "name": "Normalize Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [860, 110]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "ah1",
              "leftValue": "={{ $json.allHealthy }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
