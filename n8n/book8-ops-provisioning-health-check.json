      "id": "a1b2c3d4-rsp-0010",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1600, -40]
    },
    {
      "parameters": {},
      "id": "a1b2c3d4-nop-0011",
      "name": "NoOp Healthy Schedule",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [1600, 80]
    },
    {
      "parameters": {
        "jsCode": "const businesses = $json.businessesToRetry || [];\nconst respond = $json.respond;\nconst mode = $json.mode || 'all';\nreturn businesses.map((biz) => ({\n  json: { ...biz, _flowRespond: respond, _flowMode: mode }\n}));"
      },
      "id": "a1b2c3d4-spl-0012",
      "name": "Split Businesses",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1360, 280]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://n8n.book8.io/webhook/ops-execute-tool",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
