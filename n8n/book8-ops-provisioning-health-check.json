    {
      "parameters": {
        "jsCode": "const split = $('Split Businesses').item.json;\nreturn [{\n  json: {\n    businessId: split.businessId,\n    _flowRespond: split._flowRespond,\n    retryHttpResponse: $json\n  }\n}];"
      },
      "id": "a1b2c3d4-att-0014",
      "name": "Attach businessId After Retry",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1820, 280]
