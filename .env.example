# App
PORT=5050
NODE_ENV=development

# CORS (comma-separated origins; add http://localhost:5173 etc. for local dev frontends)
CORS_ORIGINS=https://www.book8.io,https://book8.io

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/book8-core

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_AGENT_ID=

# OpenAI (SMS AI)
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=
# Optional override for Resend "from" (default is Book8 AI <noreply@book8.io>)
# RESEND_FROM=Book8 AI <noreply@book8.io>

# API auth — writes and some provision flows
BOOK8_CORE_API_KEY=

# Internal — header x-book8-internal-secret or x-internal-secret (enumeration + /internal/* + /api/health)
CORE_API_INTERNAL_SECRET=
INTERNAL_API_SECRET=

# Cron — Authorization: Bearer <CRON_SECRET> on GET /api/cron/*
CRON_SECRET=
